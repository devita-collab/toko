    <style>
      .user-mention[href$="/devita-collab"] {
        color: var(--color-user-mention-fg);
        background-color: var(--bgColor-attention-muted, var(--color-attention-subtle));
        border-radius: 2px;
        margin-left: -2px;
        margin-right: -2px;
      }
      .user-mention[href$="/devita-collab"]:before,
      .user-mention[href$="/devita-collab"]:after {
        content: '';
        display: inline-block;
        width: 2px;
      }
    </style>


